# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd

super + shift + Escape
    bspc wm -r

# terminal emulator
super + Return
	st

# browser
super + shift + Return
	librewolf -P default-release

super + shift + p
    librewolf -P school

# rofi menus
super + @space 
	rofi -show drun -m -1

super + shift + @space
    $HOME/.local/bin/rofi-menu-selector.sh

super + n 
    rofi -theme ~/.config/rofi/calc.rasi -show calc -modi calc -no-show-match -no-sort -calc-command "echo -n '{result}' | xclip -selection clipboard"

super + q
    $HOME/.config/rofi/applets/powermenu.sh

# toggle polybar on and off
super + p
    polytoggle

# inc/dec gap size
super + i 
    gapdec

super + I
    gapinc

# minimize window
super + d
	bspc node $1 --flag sticky=on; bspc node $1 --flag hidden=on

super + shift + d 
    $HOME/.local/bin/minmenu.sh

# screenshots
super + shift + s 
    $HOME/.local/bin/shotarea.sh

super + ctrl + f
    $HOME/.local/bin/shotscreen.sh

# inc/dec volume
super + Up
    ~/.local/bin/cvol up

super + Down
    ~/.local/bin/cvol down
    
# mute audio
super + b
    ~/.local/bin/cvol mute

# mute mic
super + B
    ~/.local/bin/mic-tog
 
# inc/dec brightness
super + shift + Up
    clight up

super + shift + Down
    clight down

# window properties
super + x
    bspc node -g locked

super + X
    bspc node -g sticky

# window states
super + {t,shift + t,s, f}
	bspc node -t \~{tiled,pseudo_tiled,floating,fullscreen}

super + alt + {h,j,k,l}
  bspc node -z {left -20 0 || bspc node -z right -20 0, \
                bottom 0 20 || bspc node -z top 0 20,\
                top 0 -20 || bspc node -z bottom 0 -20,\
                right 20 0 || bspc node -z left 20 0}
# scratchpad
super + semicolon 
    scpad

# close and kill
super + {_,shift + }w
	bspc node -{c,k}

# alternate between the tiled and monocle layout
super + m
	bspc desktop -l next

# swap the current node and the biggest window
super + g
	bspc node -s biggest.local.window

# focus the node in the given direction
super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'

super + Tab
    bspc desktop -f last.local

super + bracket{left,right}
    bspc desktop -f {prev,next}

super + brace{left,right}
    bspc desktop -f {prev.occupied,next.occupied}


super + backslash
    bspc monitor -f next

super + shift + equal
    bspc node -m last --follow

# preselect the direction
super + ctrl + {h,j,k,l}
	bspc node -p {west,south,north,east}

# preselect the ratio
super + ctrl + {1-9}
	bspc node -o 0.{1-9}

# cancel the preselection for the focused node
super + ctrl + space
	bspc node -p cancel

# cancel the preselection for the focused desktop
super + ctrl + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

# move a floating window
super + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}


#
# receptacle
super + u; {h,j,k,l}
    bspc node --presel-dir {west,south,north,east} -i

super + shift + u
    for win in `bspc query -N -n .leaf.\!window`; do bspc node $win -k ; done;

super + y 
    bspc node $(bspc query -N -n) -n $(bspc query -N -n .leaf.\!window)

# bsptab-rs binds
super + v
    bsptab-rs create focused
super + V
    bsptab-rs embed focused
super + e; {h,j,k,l}
    bsptab-rs create focused {west,south,north,east}
super + E; {h,j,k,l}
    bsptab-rs transfer focused {west,south,north,east}
super + r
    bsptab-rs detach focused
super + shift + r
    bsptab-rs detach --all focused

