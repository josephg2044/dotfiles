#! /bin/sh

pgrep -x sxhkd > /dev/null || sxhkd &

# WM CONFIG
# bspc monitor eDP -d 1 2 3 4 5 6 7 8 9 0
bspc monitor DP-2 -d 1 2 3 4 5
bspc monitor DP-0 -d 6 7 8 9 0

bspc config window_gap             -1
bspc config top_padding 	       39
bspc config left_padding           21
bspc config right_padding          21
bspc config bottom_padding         21
bspc config border_width           1

bspc config pointer_motion_interval 16
bspc config split_ratio          0.55
bspc config borderless_monocle   true
bspc config single_monocle       false
bspc config gapless_monocle      true 

bspc rule -a mplayer2 state=floating
bspc rule -a ripdrag state=floating
bspc rule -a Screenkey manage=off
bspc rule -a Zathura state=tiled 
bspc rule -a Tk state=floating
bspc rule -a matplotlib state=floating
bspc rule -a Emacs state=tiled
bspc rule -a Lab state=floating


# SCRATCHPADR
scratchpad_xy="1200x800"
display_xy="1920x1200"
half_display=$(echo $display_xy | tr 'x' ' ' | cut -f1 -d' ' | xargs -I _ echo _/2 | bc)
half_scratchpad=$(echo $scratchpad_xy | tr 'x' ' ' | cut -f1 -d' ' | xargs -I _ echo _/2 | bc)
offset=$(echo ${half_display}-${half_scratchpad} | bc)
bspc rule -a scpad sticky=on state=floating rectangle=${scratchpad_xy}+${offset}+60

# BORDER COLORS
bspc config normal_border_color "#0c0e0f"
bspc config active_border_color "#232a2d"
bspc config focused_border_color "#232a2d"
bspc config presel_feedback_color '#232a2d'
# bspc config active_border_color "#232a2d"
# bspc config focused_border_color "#232a2d"

# STARTUP PROGRAMS
#
wal -R &
picom &
dunst &
rm /tmp/polybarhidden & 
# EXTRA CONFIG
# xset r rate 215 45 &
# setxkbmap us & 
# $HOME/.fehbg &
nitrogen --restore
$HOME/.config/polybar/launch.sh &
xsetroot -cursor_name left_ptr
